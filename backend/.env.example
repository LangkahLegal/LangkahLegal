# =====================================================
# ENVIRONMENT VARIABLES - LangkahLegal Backend
# =====================================================

# Application Configuration
APP_ENV=development
APP_NAME=LangkahLegal Backend

# Supabase Configuration
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_PORTOFOLIO_BUCKET=portofolio
SUPABASE_BERKAS_PENDUKUNG_BUCKET=berkas-pendukung
# Alternative if SERVICE_ROLE_KEY not available:
# SUPABASE_KEY=your_supabase_key_here

# ImgBB Configuration
IMGBB_API_KEY=your_imgbb_private_api_key_here

# Midtrans Payment Gateway Configuration
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxx
MIDTRANS_IS_PRODUCTION=false
